{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"]
  },
  "include": [
    "src/server/**/*.ts",
    "src/server/**/*.tsx",
    "src/pages/**/*.ts",
    "src/shared/**/*.ts",
    "src/shared/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist"]
}
