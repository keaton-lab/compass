{
  "name": "compass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:server",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:static": "npm run sync:static && vite",
    "build": "npm run build:static",
    "build:static": "npm run sync:static && vite build",
    "build:server": "vite build && tsup src/server/index.ts --format esm --dts --out-dir dist/server",
    "build:github": "vite build && tsup src/server/index.ts --format esm --dts --out-dir dist/server",
    "preview": "vite preview",
    "sync:static": "node scripts/sync-static-config.mjs",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --project tsconfig.client.json --noEmit && tsc --project tsconfig.server.json --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@vitejs/plugin-react": "^6.0.1",
    "framer-motion": "^11.18.2",
    "hono": "^4.12.12",
    "js-yaml": "^4.1.0",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^7.14.0",
    "simple-icons": "^16.14.0",
    "vite": "^8.0.8"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.456",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.2.1",
    "eslint": "^8",
    "jsdom": "^29.0.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
