{
  "name": "compass",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 dotenv -e .env.local -- astro dev",
    "dev:server": "ASTRO_TELEMETRY_DISABLED=1 dotenv -e .env.local -- astro dev",
    "dev:static": "npm run sync:static && ASTRO_TELEMETRY_DISABLED=1 COMPASS_RUNTIME_MODE=static dotenv -e .env.local -- astro dev",
    "build": "npm run build:static",
    "build:static": "npm run sync:static && ASTRO_TELEMETRY_DISABLED=1 COMPASS_RUNTIME_MODE=static dotenv -e .env.local -- astro build",
    "build:server": "ASTRO_TELEMETRY_DISABLED=1 dotenv -e .env.local -- astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "sync:static": "node scripts/sync-static-config.mjs",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "ASTRO_TELEMETRY_DISABLED=1 astro check && tsc --project tsconfig.server.json --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "simple-icons": "^16.15.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/node": "^10.0.4",
    "@astrojs/react": "^5.0.3",
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "astro": "^6.1.5",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
