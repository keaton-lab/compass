# 运行模式 (static | server | github)
COMPASS_RUNTIME_MODE=server

# 配置文件路径 (可选,默认为 src/config.yaml)
COMPASS_CONFIG_PATH=src/config.yaml

# Server 模式必需
COMPASS_ADMIN_TOKEN=change-me
COMPASS_SESSION_SECRET=change-me-too

# 服务端口
PORT=3000

# GitHub 模式配置 (仅在 COMPASS_RUNTIME_MODE=github 时需要)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REPO_OWNER=
# GITHUB_REPO_NAME=
# GITHUB_REPO_BRANCH=main
# GITHUB_CONFIG_PATH=src/config.yaml
