# Server mode only. Optional, defaults to public/config.yaml
COMPASS_CONFIG_PATH=public/config.local.yaml
# Server mode required. Without this, `npm run dev` and the standalone server will fail to start.
COMPASS_ADMIN_TOKEN=change-me
# Strongly recommended in production server mode.
COMPASS_SESSION_SECRET=change-me-too
# Optional, defaults to 3000
PORT=3000
